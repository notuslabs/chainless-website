      "500": { "$value": "#1C1B19", "$type": "color", "$description": "Primary dark / warm black" },
      "600": { "$value": "#181716", "$type": "color" },
      "700": { "$value": "#141312", "$type": "color" },
      "800": { "$value": "#0F0E0D", "$type": "color" },
      "900": { "$value": "#080706", "$type": "color" },
      "950": { "$value": "#040403", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#3DA66A", "$type": "color", "$description": "A11y-fixed: 5.75:1 on dark-500" },
      "warning": { "$value": "#D4890D", "$type": "color" },
      "error":   { "$value": "#E05555", "$type": "color", "$description": "A11y-fixed: 4.60:1 on dark-500" },
      "info":    { "$value": "#4A90DA", "$type": "color", "$description": "A11y-fixed: 5.16:1 on dark-500" }
    },
    "surface": {
      "default":       { "$value": "#FAFAF8", "$type": "color", "$description": "Light mode page background" },
      "warm":          { "$value": "#F0EEE9", "$type": "color", "$description": "Light mode card background" },
      "muted":         { "$value": "#F4F3F0", "$type": "color", "$description": "Light mode subtle background" },
      "dark":          { "$value": "#1C1B19", "$type": "color", "$description": "Dark surface base" },
      "dark-elevated": { "$value": "#2A2926", "$type": "color", "$description": "Dark mode card/elevated" }
    }
  },

  "font": {
    "family": {
      "sans":  { "$value": "'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "serif": { "$value": "'Fraunces', 'Newsreader', 'Georgia', 'Times New Roman', serif", "$type": "fontFamily" },
      "mono":  { "$value": "'IBM Plex Mono', 'JetBrains Mono', ui-monospace, 'SFMono-Regular', monospace", "$type": "fontFamily" }
    }
  },

  "typography": {
    "display": {
      "$value": {
        "fontFamily": "{font.family.serif}",
        "fontSize": "72px",
        "fontWeight": 700,
        "lineHeight": 1.06,
        "letterSpacing": "-0.025em"
      },
      "$type": "typography",
      "$description": "Hero headlines, campaign moments"
    },
    "h1": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "56px",
        "fontWeight": 700,
        "lineHeight": 1.07,
        "letterSpacing": "-0.025em"
      },
      "$type": "typography",
      "$description": "Page titles"
    },
    "h2": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "44px",
