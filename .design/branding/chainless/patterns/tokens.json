        "letterSpacing": "0.01em"
      },
      "$type": "typography",
      "$description": "Secondary text, metadata"
    },
    "caption": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "13px",
        "fontWeight": 400,
        "lineHeight": 1.54,
        "letterSpacing": "0.015em"
      },
      "$type": "typography",
      "$description": "Labels, helper text"
