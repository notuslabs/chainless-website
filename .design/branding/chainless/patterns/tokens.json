  "motion": {
    "ease-premium": {
      "$value": "cubic-bezier(0.32, 0.72, 0, 1)",
      "$type": "cubicBezier",
      "$description": "Confident arrival — moderate accel, slow decel"
    },
    "duration": {
      "fast":     { "$value": "150ms", "$type": "duration", "$description": "Micro-interactions" },
      "normal":   { "$value": "250ms", "$type": "duration", "$description": "Standard transitions" },
      "entrance": { "$value": "900ms", "$type": "duration", "$description": "Scroll-triggered reveals" },
      "stagger":  { "$value": "120ms", "$type": "duration", "$description": "Delay between staggered children" }
    },
    "spring-snappy": {
      "$value": { "stiffness": 200, "damping": 20 },
      "$type": "custom",
      "$description": "Quick response — buttons, magnetic interactions"
    },
    "spring-smooth": {
      "$value": { "stiffness": 120, "damping": 24 },
      "$type": "custom",
      "$description": "Gentle organic — number reveals, scale-in"
    }
  },

  "component": {
    "text": {
      "primary":         { "$value": "#FAFAF8", "$type": "color", "$description": "Body text on dark surfaces" },
      "primary-light":   { "$value": "#1C1B19", "$type": "color", "$description": "Body text on light surfaces" },
      "secondary":       { "$value": "#B0ADA6", "$type": "color", "$description": "Secondary text on dark" },
      "secondary-light": { "$value": "#6B6862", "$type": "color", "$description": "Secondary text on light" },
      "tertiary":        { "$value": "#9E9A93", "$type": "color", "$description": "Tertiary text on dark — a11y-fixed: 5.22:1 on elevated" },
      "muted":           { "$value": "#9A9590", "$type": "color", "$description": "Muted text on dark — a11y-fixed: 5.17:1 on dark-500" }
    },
    "doppelrand": {
      "radius-outer":  { "$value": "36px",  "$type": "dimension", "$description": "Outer shell radius" },
      "radius-inner":  { "$value": "30px",  "$type": "dimension", "$description": "Inner core radius (outer - gap)" },
      "gap":           { "$value": "6px",   "$type": "dimension", "$description": "Shell-to-core gap (p-1.5)" },
      "ring-color":    { "$value": "rgba(255, 255, 255, 0.04)", "$type": "color", "$description": "Outer ring default" },
      "ring-hover":    { "$value": "rgba(255, 255, 255, 0.08)", "$type": "color", "$description": "Outer ring hover" },
      "bg":            { "$value": "rgba(255, 255, 255, 0.02)", "$type": "color", "$description": "Outer shell fill" },
      "gradient-start": { "$value": "rgba(42, 41, 38, 0.7)",   "$type": "color", "$description": "Inner gradient 0%" },
      "gradient-mid":   { "$value": "rgba(28, 27, 25, 0.9)",   "$type": "color", "$description": "Inner gradient 50%" },
      "gradient-end":   { "$value": "rgba(24, 23, 22, 0.95)",  "$type": "color", "$description": "Inner gradient 100%" }
    },
    "glow": {
      "size-lg":  { "$value": "500px", "$type": "dimension", "$description": "Large atmospheric glow orb" },
      "size-md":  { "$value": "400px", "$type": "dimension", "$description": "Medium atmospheric glow orb" },
      "size-sm":  { "$value": "200px", "$type": "dimension", "$description": "Small atmospheric glow orb" },
      "blur-lg":  { "$value": "200px", "$type": "dimension", "$description": "Large glow blur" },
      "blur-md":  { "$value": "180px", "$type": "dimension", "$description": "Medium glow blur" },
      "blur-sm":  { "$value": "80px",  "$type": "dimension", "$description": "Small glow blur" }
    },
    "layout": {
      "container-content": { "$value": "1200px", "$type": "dimension", "$description": "Content max-width inside sections" },
      "section-heading":   { "$value": "clamp(2rem, 1.5rem + 2vw, 3.25rem)", "$type": "custom", "$description": "Default section heading fluid size" }
    }
