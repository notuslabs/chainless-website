    "code": {
      "$value": {
        "fontFamily": "{font.family.mono}",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.6,
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Code blocks, addresses, hashes"
    },
    "data": {
      "$value": {
        "fontFamily": "{font.family.mono}",
        "fontSize": "18px",
        "fontWeight": 500,
        "lineHeight": 1.33,
        "letterSpacing": "-0.01em"
      },
      "$type": "typography",
      "$description": "Yield percentages, amounts"
    }
