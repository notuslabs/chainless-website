      "700": { "$value": "#967200", "$type": "color" },
      "800": { "$value": "#634A00", "$type": "color" },
      "900": { "$value": "#372800", "$type": "color" },
      "950": { "$value": "#201600", "$type": "color" }
    },
    "warm": {
