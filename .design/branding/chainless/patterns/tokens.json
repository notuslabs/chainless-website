  "shadow": {
    "diffuse-warm": {
      "$value": [
        { "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px", "color": "rgba(28, 27, 25, 0.04)" },
        { "offsetX": "0px", "offsetY": "4px",  "blur": "8px",  "spread": "0px", "color": "rgba(28, 27, 25, 0.02)" },
        { "offsetX": "0px", "offsetY": "20px", "blur": "40px", "spread": "-15px", "color": "rgba(28, 27, 25, 0.06)" }
      ],
      "$type": "shadow",
      "$description": "Everyday elevation on light surfaces"
    },
    "ambient-warm": {
      "$value": [
        { "offsetX": "0px", "offsetY": "0px",  "blur": "0px",  "spread": "1px",  "color": "rgba(28, 27, 25, 0.02)" },
        { "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px",  "color": "rgba(28, 27, 25, 0.03)" },
        { "offsetX": "0px", "offsetY": "4px",  "blur": "12px", "spread": "0px",  "color": "rgba(28, 27, 25, 0.04)" },
        { "offsetX": "0px", "offsetY": "16px", "blur": "32px", "spread": "-8px", "color": "rgba(28, 27, 25, 0.06)" },
        { "offsetX": "0px", "offsetY": "32px", "blur": "64px", "spread": "-16px","color": "rgba(28, 27, 25, 0.04)" }
      ],
      "$type": "shadow",
      "$description": "Premium elevation on light surfaces"
    },
    "diffuse-dark": {
      "$value": [
        { "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px",  "color": "rgba(0, 0, 0, 0.08)" },
        { "offsetX": "0px", "offsetY": "4px",  "blur": "12px", "spread": "0px",  "color": "rgba(0, 0, 0, 0.06)" },
        { "offsetX": "0px", "offsetY": "40px", "blur": "80px", "spread": "-20px","color": "rgba(0, 0, 0, 0.4)" }
      ],
      "$type": "shadow",
      "$description": "Everyday elevation on dark surfaces"
    },
    "ambient-dark": {
      "$value": [
        { "offsetX": "0px", "offsetY": "0px",  "blur": "0px",  "spread": "1px",  "color": "rgba(0, 0, 0, 0.06)" },
        { "offsetX": "0px", "offsetY": "2px",  "blur": "4px",  "spread": "0px",  "color": "rgba(0, 0, 0, 0.06)" },
        { "offsetX": "0px", "offsetY": "8px",  "blur": "24px", "spread": "0px",  "color": "rgba(0, 0, 0, 0.08)" },
        { "offsetX": "0px", "offsetY": "24px", "blur": "48px", "spread": "-12px","color": "rgba(0, 0, 0, 0.2)" },
        { "offsetX": "0px", "offsetY": "48px", "blur": "96px", "spread": "-24px","color": "rgba(0, 0, 0, 0.15)" }
      ],
      "$type": "shadow",
      "$description": "Premium elevation on dark surfaces"
    }
