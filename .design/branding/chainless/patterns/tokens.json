  "spacing": {
    "xs":  { "$value": "4px",  "$type": "dimension", "$description": "Inline gaps, icon-to-text" },
    "sm":  { "$value": "8px",  "$type": "dimension", "$description": "Related element gaps" },
    "md":  { "$value": "14px", "$type": "dimension", "$description": "Compact section spacing (0.5 lines)" },
    "lg":  { "$value": "28px", "$type": "dimension", "$description": "Default component gaps (1 line)" },
    "xl":  { "$value": "42px", "$type": "dimension", "$description": "Section breaks (1.5 lines)" },
    "2xl": { "$value": "56px", "$type": "dimension", "$description": "Major section breaks (2 lines)" },
    "3xl": { "$value": "84px", "$type": "dimension", "$description": "Page section spacing (3 lines)" },
    "4xl": { "$value": "112px","$type": "dimension", "$description": "Hero-to-content transition (4 lines)" }
  },

  "radius": {
    "none": { "$value": "0px",    "$type": "dimension" },
    "sm":   { "$value": "4px",    "$type": "dimension", "$description": "Focus rings, small badges" },
    "md":   { "$value": "8px",    "$type": "dimension", "$description": "Buttons, inputs" },
    "lg":   { "$value": "12px",   "$type": "dimension", "$description": "Small cards, tooltips" },
    "xl":   { "$value": "16px",   "$type": "dimension", "$description": "Standard cards" },
    "2xl":  { "$value": "24px",   "$type": "dimension", "$description": "Large cards, modals" },
    "3xl":  { "$value": "36px",   "$type": "dimension", "$description": "Doppelrand outer shell" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, avatars" }
